<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_Voting_System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_Voting_System.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- ─── NAV ─── -->
    <nav class="app-nav">
        <a href="index.html" class="brand">Vote<span>Sec</span></a>
        <span class="nav-pill">LIVE ELECTION · 2026</span>

        @if (User.Identity!.IsAuthenticated)
        {
            <a href="@Url.Action("Logout", "Home")" class="nav-link-custom">
                Logout
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Home")" class="nav-link-custom">
                Registration
            </a>
        }

    </nav>

    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
